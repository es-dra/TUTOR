# TUTOR Environment Variables Template
# Copy this file to .env and fill in actual values

# === AI Provider Configuration ===
MINIMAX_API_KEY=your-minimax-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# === TUTOR Application Configuration ===
TUTOR_API_BASE=https://api.minimax.chat/v1
TUTOR_CONFIG=
TUTOR_API_KEY=your-tutor-api-key-here
TUTOR_MASTER_KEY=your-master-key-here  # For encrypting stored credentials

# === Database Configuration ===
TUTOR_DB_PATH=data/tutor_runs.db

# === Service Configuration ===
TUTOR_API_PORT=8080
TUTOR_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Redis Configuration (Optional) ===
REDIS_URL=redis://localhost:6379
