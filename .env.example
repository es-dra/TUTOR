# TUTOR 环境变量配置
# 复制此文件为 .env 并填入实际值

# === AI Provider 配置 ===

# MiniMax API Key（你已有的 coding plan）
MINIMAX_API_KEY=sk-cp-d1YpMP1TD-xxxxx

# OpenAI API Key（可选）
OPENAI_API_KEY=sk-xxxxx

# Anthropic API Key（可选，Claude 订阅用户）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API Key（可选）
GOOGLE_API_KEY=xxxxx

# === TUTOR 应用配置 ===

# 自定义 API Base URL（可选，默认使用 provider 官方地址）
TUTOR_API_BASE=https://api.minimax.chat/v1

# 配置文件路径（可选，默认自动搜索）
TUTOR_CONFIG=

# === 数据库配置 ===

# SQLite 数据库路径（可选）
TUTOR_DB_PATH=data/tutor_runs.db

# === 服务配置 ===

# API 服务端口（可选，默认 8080）
TUTOR_API_PORT=8080

# 前端开发服务器代理地址（可选）
VITE_API_PROXY=http://localhost:8080
